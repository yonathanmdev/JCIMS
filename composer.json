        "vlucas/phpdotenv": "^5.6",
        "monolog/monolog": "^3.10",
        "phpoffice/phpspreadsheet": ">=2.1.0 <3.0.0"
    },
    "config": {
        "optimize-autoloader": true,
        "allow-plugins": {
